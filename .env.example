# ============================================================================
# BEN&FIT — Variables d'environnement
# Copie ce fichier en .env.local (jamais commité) et remplis les valeurs.
# ============================================================================

# --- Supabase (obligatoire) ------------------------------------------------
# Dashboard Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ⚠️ SECRET — jamais exposée au client, jamais préfixée NEXT_PUBLIC_.
# Utilisée uniquement côté serveur (pages/api/*, lib/withAuth.js).
# Elle contourne la RLS : ne JAMAIS l'utiliser dans du code exécuté navigateur.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- IA (optionnel — désactive les fonctionnalités de génération si absent) -
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Rate limiting distribué (optionnel, recommandé en production) --------
# Sans ces deux variables, l'app utilise un rate limiter en mémoire
# (suffisant en dev, pas fiable en serverless multi-instance).
# Créer une base Redis gratuite sur https://console.upstash.com puis coller
# l'URL REST + le token ici.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
